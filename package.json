{
  "name": "@ai-foundry/atlassian-bridge",
  "version": "0.0.12",
  "description": "Just another CLI for managing Jira and Confluence from the command line.",
  "type": "module",
  "author": "Adrian Hernandez-Mendez",
  "license": "MIT",
  "engines": {
    "node": ">=22.12"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "atlassian",
    "jira",
    "confluence",
    "cli"
  ],
  "homepage": "https://github.com/adrianhdezm/atlassian-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianhdezm/atlassian-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/adrianhdezm/atlassian-bridge/issues"
  },
  "bin": {
    "atl": "dist/main.js"
  },
  "scripts": {
    "dev": "node --import=tsx src/main.ts",
    "build": "tsc -p tsconfig.node.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "release": "./scripts/release.sh",
    "ci": "pnpm lint && pnpm test && pnpm format && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
